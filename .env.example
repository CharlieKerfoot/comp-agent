# Copy to .env and fill in your values. The .env file is gitignored.

# LLM provider: "api" (uses ANTHROPIC_API_KEY) or "claude-code" (uses Claude Code subscription)
COMPETE_PROVIDER=api
COMPETE_MODEL=claude-opus-4-7

# Only needed when COMPETE_PROVIDER=api
ANTHROPIC_API_KEY=your-anthropic-api-key-here
